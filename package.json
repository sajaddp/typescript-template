{
  "name": "typescript-template",
  "version": "1.0.0",
  "description": "A template project setup for TypeScript development.",
  "main": "ts-node ./src/index.ts",
  "scripts": {
    "dev": "ts-node ./src/index.ts",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "lint:unsafe": "biome check --write --unsafe ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sajaddp/typescript-template.git"
  },
  "keywords": [
    "boilerplate",
    "dotenv",
    "node-22",
    "node-typescript-starter",
    "node",
    "nodejs",
    "pnpm",
    "project",
    "starter",
    "template",
    "ts-node",
    "typescript-starter",
    "typescript-template",
    "typescript"
  ],
  "author": "Sajad DP",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sajaddp/typescript-template/issues"
  },
  "homepage": "https://github.com/sajaddp/typescript-template#readme",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "dotenv": "^17.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
